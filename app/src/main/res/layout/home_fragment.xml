<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/d_braze_primary"
    android:padding="@dimen/padding_15dp">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/signal_icon"
        android:layout_width="15dp"
        android:layout_height="15dp"
        android:src="@drawable/d_braze_signal_icon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/battery_icon"
        android:layout_width="28dp"
        android:layout_height="14dp"
        android:layout_marginStart="@dimen/margin_10dp"
        android:src="@drawable/d_braze_battery_icon"
        app:layout_constraintBottom_toBottomOf="@id/signal_icon"
        app:layout_constraintStart_toEndOf="@+id/signal_icon"
        app:layout_constraintTop_toTopOf="@+id/signal_icon" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/battery_percentage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/margin_4dp"
        android:text="@string/d_braze_battery_level"
        android:textColor="@android:color/white"
        android:textSize="@dimen/text_size_8sp"
        app:layout_constraintBottom_toBottomOf="@+id/battery_icon"
        app:layout_constraintEnd_toEndOf="@+id/battery_icon"
        app:layout_constraintStart_toStartOf="@+id/battery_icon"
        app:layout_constraintTop_toTopOf="@+id/battery_icon" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/bluetooth_icon"
        android:layout_width="15dp"
        android:layout_height="15dp"
        android:layout_marginEnd="@dimen/margin_10dp"
        android:src="@drawable/d_braze_bluetooth_icon"
        app:layout_constraintBottom_toBottomOf="@+id/notification_icon"
        app:layout_constraintEnd_toStartOf="@+id/notification_icon"
        app:layout_constraintTop_toTopOf="@+id/notification_icon" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/notification_icon"
        android:layout_width="15dp"
        android:layout_height="15dp"
        android:src="@drawable/d_braze_notification_icon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/profile_image"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginTop="@dimen/margin_4dp"
        android:scaleType="centerCrop"
        android:src="@drawable/d_braze_profile"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/welcome_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_10dp"
        android:text="@string/good_morning"
        android:textColor="@android:color/white"
        android:textSize="@dimen/text_size_14sp"
        app:layout_constraintEnd_toEndOf="@+id/profile_image"
        app:layout_constraintStart_toStartOf="@+id/profile_image"
        app:layout_constraintTop_toBottomOf="@+id/profile_image" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/user_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_2dp"
        android:text="@string/user_name_txt"
        android:textColor="@android:color/white"
        android:textSize="@dimen/text_size_20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="@+id/welcome_text"
        app:layout_constraintStart_toStartOf="@+id/welcome_text"
        app:layout_constraintTop_toBottomOf="@+id/welcome_text" />

</androidx.constraintlayout.widget.ConstraintLayout>
