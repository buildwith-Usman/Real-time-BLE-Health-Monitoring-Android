<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/d_braze_start_nav"
    app:startDestination="@id/welcomeFragment">

    <!-- Welcome Fragment -->
    <fragment
        android:id="@+id/welcomeFragment"
        android:name="com.app.dbraze.presentation.ui.fragment.WelcomeFragment"
        android:label="Welcome"
        tools:layout="@layout/welcome_fragment">

        <action
            android:id="@+id/action_welcomeFragment_to_loginFragment"
            app:destination="@id/loginFragment" />

        <action
            android:id="@+id/action_welcomeFragment_to_signUpFragment"
            app:destination="@id/signUpFragment" />
    </fragment>


    <fragment
        android:id="@+id/loginFragment"
        android:name="com.app.dbraze.presentation.ui.fragment.LoginFragment"
        android:label="Login"
        tools:layout="@layout/login_fragment" >

        <action
            android:id="@+id/action_loginFragment_to_signUpFragment"
            app:destination="@id/signUpFragment" />

        <action
            android:id="@+id/action_loginFragment_to_forgotPasswordFragment"
            app:destination="@id/forgotPasswordFragment" />

    </fragment>

    <fragment
        android:id="@+id/signUpFragment"
        android:name="com.app.dbraze.presentation.ui.fragment.SignUpFragment"
        android:label="SignUp"
        tools:layout="@layout/sign_up_fragment" >

        <action
            android:id="@+id/action_signUpFragment_to_setPasswordFragment"
            app:destination="@id/setPasswordFragment" />

    </fragment>

    <fragment
        android:id="@+id/setPasswordFragment"
        android:name="com.app.dbraze.presentation.ui.fragment.SetPasswordFragment"
        android:label="SetPassword"
        tools:layout="@layout/set_password_fragment" />

    <fragment
        android:id="@+id/forgotPasswordFragment"
        android:name="com.app.dbraze.presentation.ui.fragment.ForgotPasswordFragment"
        android:label="ForgotPassword"
        tools:layout="@layout/forgot_password_fragment" />


</navigation>
